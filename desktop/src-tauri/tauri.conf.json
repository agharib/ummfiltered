{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UmmFiltered",
  "version": "0.1.0",
  "identifier": "com.ummfiltered.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UmmFiltered",
        "width": 820,
        "height": 690,
        "minWidth": 760,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "theme": "Dark",
        "backgroundColor": "#1c2028"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Utility",
    "icon": ["icons/icon.png"],
    "resources": {
      "../resources/macos/worker/ummfiltered-gui-worker/": "worker/ummfiltered-gui-worker"
    },
    "macOS": {
      "entitlements": "Entitlements.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "12.0",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 180,
          "y": 190
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 190
        }
      }
    }
  }
}
